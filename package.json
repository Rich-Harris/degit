{
	"name": "degit",
	"version": "2.8.5",
	"description": "Straightforward project scaffolding",
	"keywords": [
		"git",
		"scaffolding",
		"template"
	],
	"homepage": "https://github.com/Rich-Harris/degit#readme",
	"bugs": {
		"url": "https://github.com/Rich-Harris/degit/issues"
	},
	"license": "MIT",
	"author": "Rich Harris",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Rich-Harris/degit.git"
	},
	"bin": {
		"degit": "degit"
	},
	"files": [
		"help.md",
		"dist"
	],
	"main": "dist/index.js",
	"scripts": {
		"lint": "oxlint --import-plugin --fix .",
		"lint:ci": "oxlint --import-plugin --deny-warnings .",
		"knip:ci": "knip",
		"format": "oxfmt --write .",
		"format:ci": "oxfmt --check .",
		"duplicates:ci": "jscpd --gitignore --reporters console --threshold 5 rollup.config.js vitest.config.js src test",
		"dev": "npm run build -- --watch",
		"build": "rimraf dist && rollup -c",
		"test": "vitest run",
		"test:live": "LIVE_TESTS=1 vitest run test/live.test.js",
		"test:coverage": "vitest run --coverage",
		"pretest": "npm run build",
		"prepublishOnly": "npm test"
	},
	"devDependencies": {
		"@rollup/plugin-commonjs": "18.0.0",
		"@rollup/plugin-node-resolve": "11.2.1",
		"@vitest/coverage-v8": "4.1.5",
		"chalk": "4.1.0",
		"enquirer": "2.3.6",
		"eslint-plugin-security": "4.0.0",
		"fuzzysearch": "1.0.3",
		"home-or-tmp": "3.0.0",
		"https-proxy-agent": "5.0.0",
		"husky": "6.0.0",
		"jscpd": "^4.0.9",
		"knip": "6.11.0",
		"lint-staged": "10.5.4",
		"mri": "1.1.6",
		"oxfmt": "0.47.0",
		"oxlint": "1.62.0",
		"rimraf": "3.0.2",
		"rollup": "2.44.0",
		"sander": "0.6.0",
		"source-map-support": "0.5.19",
		"tar": "6.1.0",
		"tiny-glob": "0.2.8",
		"vitest": "4.1.5"
	},
	"husky": {
		"hooks": {
			"pre-commit": "lint-staged"
		}
	},
	"lint-staged": {
		"*.{js}": [
			"oxlint --import-plugin --fix --deny-warnings",
			"git add"
		],
		"**/*": [
			"oxfmt --write --no-error-on-unmatched-pattern",
			"git add"
		]
	},
	"engines": {
		"node": ">=8.0.0"
	},
	"packageManager": "bun@1.3.14"
}
