{
	"compilerOptions": {
		"target": "ES2023",
		"module": "commonjs",
		"moduleResolution": "node",
		"esModuleInterop": true,
		"allowSyntheticDefaultImports": true,
		"types": ["node"],
		"baseUrl": ".",
		"strict": true,
		"skipLibCheck": true,
		"noEmit": true
	},
	"include": [
		"src/**/*.ts",
		"src/**/*.d.ts"
	],
	"exclude": [
		"dist",
		"test"
	]
}
